[
  {
    "kind": "set",
    "settings": [
      {
        "name": "enable_json_type",
        "value": {
          "kind": "literal",
          "type": "UInt64",
          "value": "1"
        }
      }
    ]
  },
  {
    "kind": "createTable",
    "table": {
      "kind": "tableRef",
      "table": "t_github_json"
    },
    "tableElements": [
      {
        "kind": "columnDef",
        "name": "event_type",
        "type": "LowCardinality(String)",
        "defaultKind": "DEFAULT",
        "defaultExpr": {
          "kind": "functionCall",
          "name": "JSONExtractString",
          "args": [
            {
              "kind": "columnRef",
              "parts": [
                "message_raw"
              ]
            },
            {
              "kind": "literal",
              "type": "String",
              "value": "type"
            }
          ]
        }
      },
      {
        "kind": "columnDef",
        "name": "repo_name",
        "type": "LowCardinality(String)",
        "defaultKind": "DEFAULT",
        "defaultExpr": {
          "kind": "functionCall",
          "name": "JSONExtractString",
          "args": [
            {
              "kind": "columnRef",
              "parts": [
                "message_raw"
              ]
            },
            {
              "kind": "literal",
              "type": "String",
              "value": "repo"
            },
            {
              "kind": "literal",
              "type": "String",
              "value": "name"
            }
          ]
        }
      },
      {
        "kind": "columnDef",
        "name": "message",
        "type": "JSON",
        "defaultKind": "DEFAULT",
        "defaultExpr": {
          "kind": "functionCall",
          "name": "if",
          "args": [
            {
              "kind": "functionCall",
              "name": "empty",
              "args": [
                {
                  "kind": "columnRef",
                  "parts": [
                    "message_raw"
                  ]
                }
              ]
            },
            {
              "kind": "literal",
              "type": "String",
              "value": "{}"
            },
            {
              "kind": "columnRef",
              "parts": [
                "message_raw"
              ]
            }
          ]
        }
      },
      {
        "kind": "columnDef",
        "name": "message_raw",
        "type": "String",
        "defaultKind": "EPHEMERAL"
      }
    ],
    "engine": {
      "name": "MergeTree"
    },
    "orderBy": [
      {
        "kind": "columnRef",
        "parts": [
          "event_type"
        ]
      },
      {
        "kind": "columnRef",
        "parts": [
          "repo_name"
        ]
      }
    ]
  }
]