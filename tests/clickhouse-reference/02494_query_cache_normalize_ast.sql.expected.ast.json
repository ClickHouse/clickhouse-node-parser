        "name": "use_query_cache",
        "value": {
          "kind": "literal",
          "type": "Bool",
          "value": "1"
        }
      },
      {
        "name": "query_cache_nondeterministic_function_handling",
        "value": {
          "kind": "literal",
          "type": "String",
          "value": "save"
        }
      },
      {
        "name": "max_threads",
        "value": {
          "kind": "literal",
          "type": "UInt64",
          "value": "16"
        }
      }
    ],
    "leadingComments": [
      "-- Run query whose result gets cached in the query cache.",
      "-- Besides \"use_query_cache\", pass two more knobs (one QC-specific knob and one non-QC-specific knob). We just care",
      "-- *that* they are passed and not about their effect."
    ]
  },
  {
    "kind": "select",
    "select": [
      {
        "kind": "functionCall",
        "name": "COUNT",
