[
  {
    "kind": "createDatabase",
    "name": "{CLICKHOUSE_DATABASE:Identifier}",
    "engine": {
      "name": "Replicated",
      "args": [
        {
          "kind": "literal",
          "type": "String",
          "value": "/clickhouse/databases/{database}"
        },
        {
          "kind": "literal",
          "type": "String",
          "value": "shard1"
        },
        {
          "kind": "literal",
          "type": "String",
          "value": "replica1"
        }
      ]
    }
  },
  {
    "kind": "use",
    "database": "{CLICKHOUSE_DATABASE:Identifier}"
  },
  {
    "kind": "createTable",
    "table": {
      "kind": "tableRef",
      "table": "t1"
    },
    "tableElements": [
      {
        "kind": "columnDef",
        "name": "x",
        "type": {
          "name": "UInt8"
        }
      },
      {
        "kind": "columnDef",
        "name": "y",
        "type": {
          "name": "String"
        }
      }
    ],
    "engine": {
      "name": "ReplicatedMergeTree"
    },
    "orderBy": [
      {
        "expr": {
          "kind": "columnRef",
          "parts": [
            "x"
          ]
        }
      }
    ]
  },
  {
    "kind": "set",
    "settings": [
      {
        "name": "database_replicated_allow_replicated_engine_arguments",
        "value": {
          "kind": "literal",
          "type": "UInt64",
          "value": "0"
        }
      }
    ],
    "leadingComments": [
      "-- Test that `database_replicated_allow_replicated_engine_arguments=0` for *MergeTree tables in Replicated databases work as expected for `CREATE TABLE ... AS ...` queries.",
      "-- While creating t2 with the table structure of t1, the AST for the create query would contain the engine args from t1. For this kind of queries, skip this validation if",
      "-- the value of the arguments match the default values and also skip throwing an exception."
    ]
  },
  {
    "kind": "createTable",
    "table": {
      "kind": "tableRef",
      "table": "t2"
    },
    "asTable": {
      "kind": "tableRef",
      "table": "t1"
    }
  }
]